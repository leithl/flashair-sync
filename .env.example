# FlashAir WiFi
FLASHAIR_SSID=
FLASHAIR_PASSWORD=
FLASHAIR_IP=192.168.0.1
FLASHAIR_DIR=/

# Home WiFi (to reconnect after sync)
HOME_SSID=
HOME_PASSWORD=

# Local storage for downloaded CSVs
LOCAL_CSV_DIR=/home/pi/flashair-sync/csvs

# Remote server (SCP destination)
REMOTE_HOST=
REMOTE_USER=
REMOTE_DIR=

# Optional
# SSH_KEY_PATH=~/.ssh/id_ed25519
# WIFI_INTERFACE=wlan0
# COOLDOWN_MINUTES=30
# POLL_SECONDS=60

# Daemon-mode-only LAN status endpoint (GET /status returning JSON).
# Plain HTTP, no auth — only bind on a trusted LAN. Set to 0 to disable.
# STATUS_HTTP_PORT=8765

# Managed by script (do not edit)
LAST_SYNCED=
LAST_SCPD=
