# FlashAir WiFi
FLASHAIR_SSID=
FLASHAIR_PASSWORD=
FLASHAIR_IP=192.168.0.1
FLASHAIR_DIR=/

# Home WiFi (to reconnect after sync)
HOME_SSID=
HOME_PASSWORD=

# Local storage for downloaded CSVs
LOCAL_CSV_DIR=/home/pi/flashair-sync/csvs

# Remote server (SCP destination)
REMOTE_HOST=
REMOTE_USER=
REMOTE_DIR=

# Optional
# SSH_KEY_PATH=~/.ssh/id_ed25519
# WIFI_INTERFACE=wlan0
# COOLDOWN_MINUTES=30
# POLL_SECONDS=60

# Defensive: run `sudo ufw reload` after every reconnect_home(). Only
# useful when this Pi co-hosts an AP+STA WiFi bridge (e.g. a hostapd-served
# IoT pairing AP) and `ufw-after-input` has been seen to silently drop the
# bridge's DHCP. Default off — most installs don't need this.
# UFW_RELOAD_ON_RECONNECT=0

# Managed by script (do not edit)
LAST_SYNCED=
LAST_SCPD=
