# FlashAir WiFi
FLASHAIR_SSID=
FLASHAIR_PASSWORD=
FLASHAIR_IP=192.168.0.1
FLASHAIR_DIR=/

# Home WiFi (to reconnect after sync)
HOME_SSID=
HOME_PASSWORD=

# Local storage for downloaded CSVs
LOCAL_CSV_DIR=/home/pi/flashair-sync/csvs

# Remote server (SCP destination)
REMOTE_HOST=
REMOTE_USER=
REMOTE_DIR=

# Optional
# SSH_KEY_PATH=~/.ssh/id_ed25519
# WIFI_INTERFACE=wlan0
# COOLDOWN_MINUTES=30
# POLL_SECONDS=60

# Optional: screenshot path (BMPs from the card's /Screenshot/ dir).
# All three required together, or all left blank. Recommended:
# LOCAL_SHOT_DIR on tmpfs to avoid SD-card wear (~2.81 MB per BMP).
# FLASHAIR_SHOT_DIR=/Screenshot
# LOCAL_SHOT_DIR=/run/flashair-shots
# REMOTE_SHOT_DIR=

# Managed by script (do not edit)
LAST_SYNCED=
LAST_SCPD=
LAST_SHOT_SCPD=
